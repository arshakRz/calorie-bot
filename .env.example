# Copy this file to .env for local testing (never commit the real .env!)
# On Railway, set these under your service → Variables tab.

TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
GROUP_CHAT_ID=-1001234567890

OPENAI_API_KEY=sk-...

# Your Telegram numeric user ID (get it from @userinfobot)
USER1_ID=123456789
USER1_NAME=Max

# Your GF's Telegram numeric user ID
USER2_ID=987654321
USER2_NAME=Anna

# Optional – defaults to calories.db in the working directory
# DB_PATH=/data/calories.db
